# traps (ctrl-c)
killproc() {
	echo -e "\n**** Received SIGINT, aborting! ****\n"
	kill -- -$$ && exit 2
}

exitproc() {
	echo -e "\n-> Removing temporary files..."
	rm -f "$WORKDIR"/run* "$WORKDIR"/stressC "$WORKDIR"/schbench_raw \
	      "$WORKDIR"/*.txt "$WORKDIR"/*.jpg "$WORKDIR"/*.ppm
	rm -f "$LOCKFILE"

	if [[ "$CLEANUP" == "true" ]]; then
		echo -e "-> Cleaning up downloaded archives and extracted directories..."
		rm -f "$WORKDIR"/firefox102.tar.xz "$WORKDIR"/*.zst "$WORKDIR"/*.7z \
		      "$WORKDIR"/ffmpeg.tar.xz "$WORKDIR"/namd.tar.gz "$WORKDIR"/namd-example.tar.gz \
		      "$WORKDIR"/linux-$KERNVER.tar.xz "$WORKDIR"/y-cruncher.tar.xz
		rm -rf "$WORKDIR/ffmpeg-$FFMPEGVER" \
		       "$WORKDIR/namd" \
		       "$WORKDIR/linux-$KERNVER" \
		       "$WORKDIR/y-cruncher v$YCRUNCHER_VER-static" \
		       "$WORKDIR/firefox102.tar" \
		       "$WORKDIR/bosphorus_hd.y4m"
	fi
	echo -e "${TB}Bye!${TN}\n"
}

# vars
export LANG=C
CURRDIR=$(pwd)
SCRIPTDIR=$(dirname "$(readlink -f "$0")")
TMP="/tmp"
VER="v2.2"
FFMPEGVER="7.0.1"
YCRUNCHER_VER="0.8.6.9545"
KERNEL_NAME=$(uname -r)
CDATE=$(date +%F-%H%M)
RAMSIZE=$(awk '/MemTotal/{print int($2 / 1000)}' /proc/meminfo)
CPUCORES=$(nproc)
CPUFREQ=$(awk '{print $1 / 1000000}' /sys/devices/system/cpu/cpufreq/policy0/cpuinfo_max_freq)
COEFF="$(python -c "print(round((($CPUCORES + 1) / 2 * $CPUFREQ / 2) ** (1/3),2))")"
KERNVER="6.14.7"
# system info will be logged
SYSINFO=$(inxi -CmSz -c0 -y-1 | sed -e "s/Array.*:.*//;/^\s*$/d")

# Set defaults as none
SCX="none"
SCX_VERSION=""
# update if we find them below

if [ -f "/sys/kernel/sched_ext/root/ops" ]; then
	TMP=$(cat "/sys/kernel/sched_ext/root/ops")
	if [ -n "$TMP" ]; then
		SCX=$(awk -F'[[:digit:]]' '{print $1}' "/sys/kernel/sched_ext/root/ops" | sed -rn 's/^(.*)_$/\1/p')
		SCX_VERSION=$(sed -rn 's/^[^0-9]*([0-9]+(\.[0-9]+)+).*$/\1/p' "/sys/kernel/sched_ext/root/ops")
		[[ -z "$SCX" ]] && SCX="$TMP"
	fi
fi

VERSION=$(pacman -Qi cachyos-benchmarker 2>/dev/null | grep "Version         :" || true)
# allow more open files, needed by perf bench msg
ulimit -n 4096

